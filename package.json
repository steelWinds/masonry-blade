{
	"name": "masonry-blade",
	"version": "2.0.0",
	"private": false,
	"description": "masonry-blade is a tiny, fast, and extensible engine for masonry grid calculation with zero dependencies 🤤",
	"keywords": [
		"balanced",
		"balanced-masonry",
		"engine",
		"lib",
		"low-level",
		"masonry",
		"masonry-grid",
		"masonry-js"
	],
	"homepage": "https://github.com/steelWinds/masonry-blade",
	"bugs": {
		"url": "https://github.com/steelWinds/masonry-blade/issues",
		"email": "kirillsurov0@gmail.com"
	},
	"license": "MPL-2.0",
	"author": "steelWinds",
	"repository": {
		"type": "git",
		"url": "https://github.com/steelWinds/masonry-blade"
	},
	"files": [
		"build",
		"README.md",
		"README.ru.md",
		"LICENSE"
	],
	"type": "module",
	"types": "./build/index.d.ts",
	"exports": {
		".": "./build/index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown --minify",
		"build:watch": "tsdown --sourcemap --watch",
		"test": "vitest",
		"test:bench": "vitest bench",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"lint": "oxlint --type-aware",
		"lint:fix": "oxlint --fix --type-aware",
		"nano-staged": "nano-staged",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"prepare": "husky"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@faker-js/faker": "^10.3.0",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.1",
		"cross-env": "^10.1.0",
		"fast-check": "^4.6.0",
		"husky": "^9.1.7",
		"nano-staged": "^0.9.0",
		"oxfmt": "^0.38.0",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.1",
		"publint": "^0.3.18",
		"tsdown": "0.21.2",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3",
		"unplugin-remove": "^1.0.3",
		"vitest": "^4.1.1"
	},
	"overrides": {
		"tsdown": "0.21.4"
	},
	"nano-staged": {
		"*": "oxfmt --no-error-on-unmatched-pattern",
		"*.{js,jsx,ts,tsx,mjs,cjs}": [
			"pnpm run lint",
			"pnpm run test:run --passWithNoTests"
		]
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"volta": {
		"node": "22.18.0",
		"pnpm": "10.32.1"
	}
}
